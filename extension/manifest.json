{
  "manifest_version": 3,
  "name": "CogniShield Extension",
  "version": "1.0",
  "description": "A unified sensory firewall for inclusive web access.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": ["storage", "tabs", "contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "observer.js",
        "aiClient.js",
        "features/visualGuard.js",
        "features/spotlight.js",
        "features/focusMode.js",
        "features/readability.js",
        "main.js"
      ],
      "run_at": "document_start"
    }
  ]
}