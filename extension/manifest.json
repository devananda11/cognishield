{
  "manifest_version": 3,
  "name": "CogniShield Extension",
  "version": "1.0",
  "description": "CogniShield browser extension.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["observer.js", "aiClient.js", "features/visualGuard.js", "features/readability.js","main.js"]
    }
  ]
}
